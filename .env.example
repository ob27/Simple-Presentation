# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and never committed.
#
# Simple-Diagram shares the "oestler" Firebase project with Simple Kanban —
# get these from Firebase Console (project "oestler") → Project Settings →
# Your apps → "simple-diagrams" web app config.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=oestler.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=oestler
VITE_FIREBASE_STORAGE_BUCKET=oestler.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Realtime Database URL — used for live cursors/presence.
VITE_FIREBASE_DATABASE_URL=https://oestler-default-rtdb.asia-southeast1.firebasedatabase.app

# Same reCAPTCHA v3 site key used by Simple Kanban (App Check) — shared
# per-project/domain, no need to register a new one.
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
